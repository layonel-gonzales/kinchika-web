/* ==========================================================
   RESET + BASE
   ========================================================== */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body { width: 100%; overflow-x: hidden; }
html { scroll-behavior: auto; }
body {
  color: #ffffff;
  font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, sans-serif;
  font-weight: 300;
  line-height: 1.6;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}
img { max-width: 100%; display: block; }
a { color: inherit; text-decoration: none; }
button { font-family: inherit; cursor: pointer; border: none; background: none; color: inherit; }

/* ==========================================================
   FONDO PROFUNDIDAD GLOBAL — gradiente que se ajusta vía JS
   ========================================================== */
#deep-bg {
  position: fixed; 
  inset: 0;
  z-index: -10;
  /* Degradado inicial más oscuro: de Azul Marino a Azul Profundo */
  transition: background 0.8s ease;
}

/* Vignette */
#vignette {
  position: fixed; inset: 0; pointer-events: none; z-index: 5;
  background: radial-gradient(ellipse at center, transparent 50%, rgba(0,0,0,0.55) 100%);
  transition: opacity .6s ease;
}

/* God rays — Rayos de luz solares concentrados, disminuyen con profundidad */
.god-rays {
  position: fixed; inset: 0; pointer-events: none; z-index: 0;
  background:
    radial-gradient(ellipse 25% 40% at 50% -5%,
      rgba(255,255,255,0.8) 0%,
      rgba(255,255,255,0.4) 30%,
      transparent 100%),
    conic-gradient(
      from 90deg at 50% 0%,
      rgba(255,255,255,0.4) 0deg,
      rgba(255,255,255,0.35) 15deg,
      rgba(255,255,255,0.2) 30deg,
      rgba(255,255,255,0.38) 50deg,
      rgba(255,255,255,0.22) 70deg,
      rgba(255,255,255,0.42) 90deg,
      rgba(255,255,255,0.22) 110deg,
      rgba(255,255,255,0.35) 130deg,
      rgba(255,255,255,0.2) 150deg,
      rgba(255,255,255,0.3) 165deg,
      transparent 180deg
    );
  mix-blend-mode: screen;
  opacity: 1;
  transition: opacity 0.3s ease;
}

/* Ascent shimmer — destellos de luz como cuando miras hacia arriba bajo el agua */
#ascent-shimmer {
  position: fixed; inset: 0; pointer-events: none; z-index: 2;
  opacity: 0;
  transition: opacity 1.2s ease;
  background:
    radial-gradient(ellipse 80% 40% at 50% 0%,
      rgba(180, 220, 255, 0.45) 0%,
      rgba(150, 200, 240, 0.18) 30%,
      transparent 60%),
    conic-gradient(
      from 90deg at 50% 0%,
      transparent 0deg,
      rgba(220, 240, 255, 0.18) 12deg,
      transparent 20deg,
      rgba(255, 255, 255, 0.22) 32deg,
      transparent 44deg,
      rgba(200, 230, 255, 0.15) 56deg,
      transparent 70deg,
      rgba(255, 255, 255, 0.20) 84deg,
      transparent 100deg,
      rgba(220, 240, 255, 0.12) 116deg,
      transparent 130deg,
      rgba(255, 255, 255, 0.18) 144deg,
      transparent 160deg,
      rgba(200, 230, 255, 0.14) 172deg,
      transparent 180deg
    );
  mix-blend-mode: screen;
  animation: shimmerRays 7s ease-in-out infinite alternate;
}
@keyframes shimmerRays {
  0%   { transform: translateX(-25px) scale(1); filter: brightness(1); }
  50%  { transform: translateX(15px) scale(1.04); filter: brightness(1.18); }
  100% { transform: translateX(30px) scale(1.07); filter: brightness(0.92); }
}
#ascent-shimmer::after {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(circle at 30% 0%, rgba(255,255,255,0.4) 0%, transparent 18%),
              radial-gradient(circle at 70% 0%, rgba(200,230,255,0.35) 0%, transparent 22%),
              radial-gradient(circle at 50% 0%, rgba(255,255,255,0.55) 0%, transparent 14%);
  animation: shimmerSparkle 4s ease-in-out infinite alternate;
  mix-blend-mode: screen;
}
@keyframes shimmerSparkle {
  0%   { opacity: 0.6; transform: scale(1) translateX(0); }
  50%  { opacity: 1;   transform: scale(1.05) translateX(10px); }
  100% { opacity: 0.7; transform: scale(0.98) translateX(-8px); }
}

/* Caustics canvas (rocas) */
#caustics-canvas {
  position: fixed; inset: 0; pointer-events: none; z-index: 1;
  opacity: 0; transition: opacity 1s ease;
  mix-blend-mode: screen;
}

/* Three.js bubbles canvas */
#bubbles-canvas {
  position: fixed; inset: 0; pointer-events: none; z-index: 3;
  opacity: 0; transition: opacity 1s ease;
}

/* ==========================================================
   AUDIO OVERLAY
   ========================================================== */
#audio-overlay {
  position: fixed; inset: 0; z-index: 9999;
  background: radial-gradient(circle at center, #001F3F 0%, #000508 100%);
  display: flex; align-items: center; justify-content: center;
  flex-direction: column; gap: 28px; padding: 24px; text-align: center;
  transition: opacity .8s ease, visibility .8s ease;
}
#audio-overlay.hidden { opacity: 0; visibility: hidden; pointer-events: none; }
#audio-overlay h2 {
  font-family: 'Fraunces', serif; font-weight: 400;
  font-size: clamp(28px, 4vw, 44px); letter-spacing: .02em;
  max-width: 720px;
}
#audio-overlay p { color: rgba(255,255,255,.7); max-width: 540px; }
.overlay-buttons { display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; }
.btn-primary, .btn-ghost {
  padding: 14px 28px; border-radius: 999px; font-weight: 500; letter-spacing: .04em;
  font-size: 14px; text-transform: uppercase; transition: all .25s ease;
}
.btn-primary {
  background: linear-gradient(135deg, #C9A84C, #e3c46a);
  color: #001F3F;
}
.btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 30px rgba(201,168,76,.4); }
.btn-ghost {
  border: 1px solid rgba(255,255,255,.3); color: rgba(255,255,255,.85);
}
.btn-ghost:hover { background: rgba(255,255,255,.1); }

/* ==========================================================
   AUDIO TOGGLE (esquina superior derecha)
   ========================================================== */
#audio-toggle {
  position: fixed; top: 18px; right: 18px; z-index: 200;
  width: 48px; height: 48px; border-radius: 50%;
  background: rgba(0,15,30,.55); border: 1px solid rgba(255,255,255,.18);
  display: flex; align-items: center; justify-content: center;
  font-size: 20px; backdrop-filter: blur(10px);
  transition: all .25s ease;
}
#audio-toggle:hover { transform: scale(1.08); background: rgba(0,30,60,.7); }

/* ==========================================================
   NAV
   ========================================================== */
#topnav {
  position: fixed; top: 18px; left: 18px; z-index: 200;
  display: flex; gap: 18px; align-items: center;
  background: rgba(0,15,30,.45); backdrop-filter: blur(12px);
  padding: 10px 18px; border-radius: 999px;
  border: 1px solid rgba(255,255,255,.12);
}
#topnav .brand {
  font-family: 'Fraunces', serif; font-weight: 700;
  font-size: 14px; letter-spacing: .12em; text-transform: uppercase;
  color: #C9A84C;
}
#topnav a {
  font-size: 12px; letter-spacing: .08em; text-transform: uppercase;
  color: rgba(255,255,255,.75); transition: color .2s;
}
#topnav a:hover { color: #fff; }
@media (max-width: 720px) {
  #topnav .nav-links { display: none; }
}
.nav-links { display: flex; gap: 16px; }

/* ==========================================================
   HUD (computador de buceo)
   ========================================================== */
#hud {
  position: fixed; bottom: 22px; left: 22px; z-index: 100;
  font-family: 'Share Tech Mono', monospace;
  background: rgba(0,15,30,.62);
  border: 1px solid rgba(0, 255, 200, .18);
  border-radius: 14px;
  padding: 14px 18px; min-width: 220px;
  backdrop-filter: blur(8px);
  box-shadow: 0 0 30px rgba(0,255,200,.06), inset 0 0 12px rgba(0,255,200,.05);
  transition: opacity .8s ease, transform .8s ease;
}
#hud.hidden-hud { opacity: 0; transform: translateY(20px); pointer-events: none; }
.hud-row { display: flex; justify-content: space-between; gap: 16px; font-size: 13px; line-height: 1.7; }
.hud-row .label { color: rgba(0,255,200,.6); letter-spacing: .08em; }
.hud-row .val { color: #00ffaa; font-weight: 500; }
.hud-row.warn .val { color: #ff5252; animation: pulseRed 1s infinite; }
@keyframes pulseRed {
  0%, 100% { opacity: 1; }
  50% { opacity: .4; }
}
#hud .hud-title {
  font-size: 10px; color: rgba(0,255,200,.5); letter-spacing: .2em;
  text-transform: uppercase; border-bottom: 1px solid rgba(0,255,200,.15);
  padding-bottom: 6px; margin-bottom: 8px;
}
@media (max-width: 600px) {
  #hud { left: 12px; bottom: 12px; padding: 10px 14px; min-width: 180px; }
}

/* ==========================================================
   SECCIÓN BASE — SIN BACKGROUND para mantener degradado visible
   ========================================================== */
section {
  position: relative;
  min-height: 100vh;
  padding: 120px 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent; /* Asegura que el degradado del fondo sea visible */
}
.container { width: 100%; max-width: 1200px; margin: 0 auto; position: relative; z-index: 4; }

/* ==========================================================
   APNEÍSTA — Estilos movidos a css/diver.css
   ========================================================== */

/* ==========================================================
   HERO — SUPERFICIE
   ========================================================== */
#hero {
  background: transparent;
  position: relative;
  text-align: center; overflow: hidden;
}
#hero::before {
  content: ''; position: absolute; inset: 0;
  background: transparent;
  animation: surfaceWaves 10s ease-in-out infinite;
}
@keyframes surfaceWaves {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8px); }
}
.hero-content { position: relative; z-index: 4; }
.hero-content h1 {
  font-family: 'Fraunces', serif;
  font-size: clamp(40px, 8vw, 110px);
  font-weight: 400; line-height: 1.05;
  letter-spacing: -0.02em;
  margin-bottom: 24px;
  color: #ffffff;
}
.hero-subtitle {
  font-size: clamp(14px, 1.6vw, 18px);
  letter-spacing: .3em; text-transform: uppercase;
  color: rgba(255,255,255,.92); margin-bottom: 60px;
  font-weight: 500;
}
.cta-descend {
  display: inline-flex; align-items: center; gap: 12px;
  padding: 18px 40px; border-radius: 999px;
  background: rgba(0, 31, 63, .8);
  border: 1px solid rgba(255,255,255,.4);
  color: #fff;
  font-size: 13px; letter-spacing: .25em; text-transform: uppercase;
  font-weight: 500;
  animation: pulseCTA 2.4s ease-in-out infinite;
}
.cta-descend:hover { background: #001F3F; transform: translateY(2px); }
@keyframes pulseCTA {
  0%, 100% { box-shadow: 0 0 0 0 rgba(255,255,255,.5); }
  50% { box-shadow: 0 0 0 18px rgba(255,255,255,0); }
}

/* FALLBACK: Asegurar visibilidad de elementos data-reveal */
/* Si JavaScript está lento o hay errores en ScrollTrigger, los elementos deben ser visibles */
[data-reveal] {
  opacity: 1 !important;
  visibility: visible !important;
  transform: translate(0, 0) scale(1) !important;
  transition: opacity 0.3s ease !important;
}

/* Fallback si JavaScript falla completamente */
@supports not (animation: none) {
  [data-reveal] { opacity: 1 !important; transform: none !important; visibility: visible !important; }
}
noscript [data-reveal] { opacity: 1 !important; transform: none !important; visibility: visible !important; }

/* split text — hero */
.char { display: inline-block; opacity: 0; transform: translateY(20px); }
/* headings de sección: cada palabra es un clip vertical */
.js-heading .word { display: inline-block; overflow: hidden; vertical-align: bottom; }
.js-heading .char { transform: translateY(110%); opacity: 1; }
/* eyebrows: arrancan sin letter-spacing, JS los expande */
.js-eyebrow { letter-spacing: 0em !important; opacity: 0; }

/* ==========================================================
   PÁRRAFOS BASE — Estándar de color para todo el sitio
   ========================================================== */
p {
  color: rgba(255,255,255,.88);
  font-size: 16px;
  line-height: 1.8;
  background: rgba(201, 168, 76, 0.12);
  padding: 20px 24px;
  border-radius: 12px;
  border-left: 3px solid rgba(201, 168, 76, 0.4);
  margin: 16px 0;
  transition: all 0.3s ease;
}

p:hover {
  background: rgba(201, 168, 76, 0.18);
  border-left-color: rgba(201, 168, 76, 0.6);
}

/* ==========================================================
   SECCIÓN ZONA INFO
   ========================================================== */
.zone {
  text-align: center;
}
.zone-meta {
  font-family: 'Share Tech Mono', monospace;
  font-size: 11px; letter-spacing: .35em; text-transform: uppercase;
  color: rgba(0,255,200,.65);
  margin-bottom: 18px;
}
.zone h2 {
  font-family: 'Fraunces', serif;
  font-size: clamp(36px, 5vw, 64px);
  font-weight: 400; letter-spacing: -.01em;
  margin-bottom: 22px;
  color: #fff;
  max-width: 800px; margin-left: auto; margin-right: auto;
}

/* ==========================================================
   SISTEMA DE CARDS NORMALIZADO
   ========================================================== */
.card {
  background: rgba(0,15,30,.75);
  border: 1px solid rgba(255,255,255,.2);
  border-radius: 18px;
  overflow: hidden;
  transition: all .3s ease;
  position: relative;
}
.card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 30px rgba(0,0,0,.3);
}

/* ==========================================================
   FAUNA CARDS / SWIPER
   ========================================================== */
.fauna-section { padding: 100px 0; }
.fauna-section .swiper { padding: 30px 24px; }
.fauna-card,
.card--fauna {
  backdrop-filter: blur(6px);
  height: 100%;
  display: flex;
  flex-direction: column;
}
.fauna-card .img-wrap {
  aspect-ratio: 4/3; background: #002040;
  background-size: cover; background-position: center;
  position: relative;
}
.fauna-card .img-wrap::after {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(180deg, transparent 50%, rgba(0,15,30,.7) 100%);
}
.fauna-card .body { padding: 22px; }
.fauna-card h3 {
  font-family: 'Fraunces', serif; font-weight: 700;
  font-size: 22px; margin-bottom: 4px;
}
.fauna-card .latin { font-style: italic; color: rgba(255,255,255,.5); font-size: 13px; margin-bottom: 12px; }
.fauna-card p {
  background: rgba(201, 168, 76, 0.12);
  padding: 14px 16px;
  border-radius: 8px;
  border-left: 3px solid rgba(201, 168, 76, 0.4);
  margin: 12px 0;
  transition: all 0.3s ease;
}
.fauna-card p:hover {
  background: rgba(201, 168, 76, 0.18);
  border-left-color: rgba(201, 168, 76, 0.6);
}

/* ==========================================================
   GALLERY
   ========================================================== */
.gallery-swiper .swiper-slide {
  height: 460px; border-radius: 18px; overflow: hidden;
  background-size: cover; background-position: center;
  position: relative;
}
.gallery-swiper .swiper-slide::after {
  content: attr(data-caption);
  position: absolute; bottom: 24px; left: 24px; right: 24px;
  font-family: 'Fraunces', serif; font-size: 22px;
  text-shadow: 0 2px 12px rgba(0,0,0,.6);
}

/* ==========================================================
   TRANSICIÓN A SECCIONES "REALES"
   ========================================================== */
#editorial-divider {
  background: transparent;
  min-height: 50vh;
  text-align: center;
}
#editorial-divider h2 {
  font-family: 'Fraunces', serif;
  font-size: clamp(32px, 5vw, 60px);
  font-weight: 400;
  margin-bottom: 16px;
  color: #ffffff;
}
/* Heredar color base, solo ancho especial */
#editorial-divider .lead {
  max-width: 580px;
  margin: 0 auto;
  color: rgba(255,255,255,.92);
  background: rgba(201, 168, 76, 0.12);
  padding: 24px 28px;
  border-radius: 12px;
  border-left: 3px solid rgba(201, 168, 76, 0.4);
  transition: all 0.3s ease;
}

#editorial-divider .lead:hover {
  background: rgba(201, 168, 76, 0.18);
  border-left-color: rgba(201, 168, 76, 0.6);
}

/* ==========================================================
   EVENTOS Y SECCIONES DEL CLUB — fondo transparente para mostrar degradado
   ========================================================== */
.club-section {
  background: transparent !important; /* Fuerza transparencia para que solo se vea el degradado del fondo */
  padding: 120px 24px;
}
.section-head {
  text-align: center; margin-bottom: 60px;
}
.section-head .eyebrow {
  font-size: 12px; letter-spacing: .35em; text-transform: uppercase;
  color: #C9A84C; margin-bottom: 16px;
}
.section-head h2 {
  font-family: 'Fraunces', serif;
  font-weight: 400; font-size: clamp(36px, 5vw, 64px);
  margin-bottom: 12px;
}
.section-head p { color: rgba(255,255,255,.88); max-width: 620px; margin: 0 auto; }

/* Filtros */
.filters {
  display: flex; flex-wrap: wrap; gap: 14px; justify-content: center;
  margin-bottom: 50px; align-items: center;
}
.filter-tabs { display: flex; flex-wrap: wrap; gap: 8px; }
.filter-tabs button {
  padding: 10px 18px; border-radius: 999px;
  background: rgba(255,255,255,.05);
  border: 1px solid rgba(255,255,255,.1);
  font-size: 12px; letter-spacing: .1em; text-transform: uppercase;
  color: rgba(255,255,255,.7);
  transition: all .2s;
}
.filter-tabs button.active {
  background: #C9A84C; color: #001F3F; border-color: #C9A84C;
}
.filter-tabs button:hover:not(.active) {
  background: rgba(255,255,255,.1); color: #fff;
}
.filter-row {
  display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; align-items: center;
}
.filter-row select {
  padding: 10px 16px; border-radius: 999px;
  background: rgba(255,255,255,.05);
  border: 1px solid rgba(255,255,255,.15);
  color: #fff; font-size: 13px;
  font-family: inherit;
}
.toggle-only { display: flex; align-items: center; gap: 8px; font-size: 13px; color: rgba(255,255,255,.7); }
.toggle-only input { accent-color: #C9A84C; }

/* Grid eventos */
.events-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  gap: 30px;
}
.event-card,
.card--event {
  display: flex;
  flex-direction: column;
}
.event-card:hover { transform: translateY(-6px); box-shadow: 0 20px 40px rgba(0,0,0,.35); }
.event-card .image {
  aspect-ratio: 16/9;
  background-size: cover; background-position: center;
  position: relative;
}
.event-card .image::after {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(180deg, transparent 40%, rgba(0,15,30,.85) 100%);
}
.event-card .badge {
  position: absolute; top: 16px; left: 16px; z-index: 2;
  padding: 6px 12px; border-radius: 999px;
  font-size: 11px; letter-spacing: .14em; text-transform: uppercase; font-weight: 600;
}
.badge.ABIERTO { background: #2ecc71; color: #00211a; }
.badge.PROXIMO { background: #f1c40f; color: #2d2400; }
.badge.AGOTADO { background: #e74c3c; color: #fff; }

.event-card .date-block {
  position: absolute; bottom: 16px; left: 16px; z-index: 2;
  background: rgba(0,15,30,.7); backdrop-filter: blur(6px);
  border-radius: 12px; padding: 10px 14px;
  text-align: center; min-width: 64px;
}
.event-card .date-block .day {
  font-size: 26px; font-weight: 700; line-height: 1; color: #C9A84C;
}
.event-card .date-block .month {
  font-size: 11px; letter-spacing: .2em; text-transform: uppercase;
  color: rgba(255,255,255,.7);
}
.event-card .body { padding: 24px; flex: 1; display: flex; flex-direction: column; }
.event-card h3 {
  font-family: 'Fraunces', serif; font-weight: 700;
  font-size: 22px; margin-bottom: 12px;
}
.event-card .meta {
  display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 14px;
  font-size: 12px;
}
.event-card .meta .chip {
  padding: 4px 10px; border-radius: 999px;
  background: rgba(201,168,76,.15);
  color: #C9A84C; letter-spacing: .08em; text-transform: uppercase;
  font-weight: 500;
}
.event-card .info-line {
  display: flex; align-items: center; gap: 8px;
  font-size: 13px; color: rgba(255,255,255,.7);
  margin-bottom: 8px;
}
.event-card .info-line .ic { color: #C9A84C; }
.event-card .footer {
  display: flex; justify-content: space-between; align-items: center;
  margin-top: auto; padding-top: 16px;
  border-top: 1px solid rgba(255,255,255,.08);
}
.event-card .cupos { font-size: 12px; color: rgba(255,255,255,.6); }
.btn-detail {
  padding: 10px 18px; border-radius: 999px;
  background: #C9A84C; color: #001F3F;
  font-size: 12px; letter-spacing: .12em; text-transform: uppercase; font-weight: 600;
  transition: all .25s;
}
.btn-detail:hover { transform: translateX(3px); background: #e3c46a; }

/* ==========================================================
   RESULTADOS
   ========================================================== */
#resultados-section {
  background: transparent;
}
.result-selector {
  display: flex; justify-content: center; margin-bottom: 40px;
}
.result-selector select {
  padding: 14px 22px; border-radius: 12px;
  background: rgba(255,255,255,.06);
  border: 1px solid rgba(255,255,255,.18);
  color: #fff; font-size: 15px; font-family: inherit;
  min-width: 320px;
}

.result-card,
.card--result {
  padding: 40px;
  margin-bottom: 30px;
}
.result-head {
  display: flex; justify-content: space-between; align-items: flex-start;
  flex-wrap: wrap; gap: 20px;
  border-bottom: 1px solid rgba(255,255,255,.1);
  padding-bottom: 22px; margin-bottom: 28px;
}
.result-head h3 {
  font-family: 'Fraunces', serif; font-weight: 700;
  font-size: 28px; margin-bottom: 4px;
}
.result-head .meta {
  color: rgba(255,255,255,.6); font-size: 14px;
}
.btn-acta {
  padding: 10px 18px; border-radius: 999px;
  background: rgba(201,168,76,.35); color: #ffffff;
  border: 1px solid #C9A84C;
  font-size: 12px; letter-spacing: .1em; text-transform: uppercase; font-weight: 500;
}
.btn-acta:hover { background: rgba(201,168,76,.5); }

.discipline-block { margin-bottom: 36px; }
.discipline-block h4 {
  font-size: 13px; letter-spacing: .3em; text-transform: uppercase;
  color: #C9A84C; margin-bottom: 14px; font-weight: 600;
}
.results-table {
  width: 100%; border-collapse: collapse;
  font-size: 14px;
}
.results-table th {
  text-align: left; padding: 12px 16px;
  font-size: 11px; letter-spacing: .2em; text-transform: uppercase;
  color: rgba(255,255,255,.5); font-weight: 500;
  border-bottom: 1px solid rgba(255,255,255,.1);
}
.results-table td {
  padding: 14px 16px;
  border-bottom: 1px solid rgba(255,255,255,.06);
}
.results-table tr.first-place {
  background: linear-gradient(90deg, rgba(201,168,76,.18), rgba(201,168,76,0));
  position: relative;
}
.results-table tr.first-place td:first-child { color: #C9A84C; font-weight: 700; font-size: 16px; }
.results-table tr.first-place::before {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(90deg, transparent, rgba(255,215,0,.08), transparent);
  animation: shimmer 3s infinite;
  pointer-events: none;
}
@keyframes shimmer {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(100%); }
}
.record-badge {
  display: inline-block; padding: 3px 8px; border-radius: 6px;
  font-size: 10px; letter-spacing: .1em; text-transform: uppercase;
  font-weight: 600; margin-left: 8px;
}
.record-badge.nacional { background: #C9A84C; color: #001F3F; }
.record-badge.club { background: #4a90e2; color: #fff; }
@media (max-width: 700px) {
  .results-table { font-size: 12px; }
  .results-table th, .results-table td { padding: 10px 8px; }
}

/* ==========================================================
   ORGANIGRAMA
   ========================================================== */
#directiva-section {
  background: transparent;
  padding: 120px 24px;
}
.year-tabs {
  display: flex; gap: 6px; justify-content: center; flex-wrap: wrap;
  margin-bottom: 16px;
}
.year-tabs button {
  padding: 12px 20px; font-size: 18px; font-weight: 500;
  position: relative; color: rgba(255,255,255,.5);
  transition: color .2s;
  font-family: 'Fraunces', serif;
}
.year-tabs button.active { color: #C9A84C; }
.year-tabs button.active::after {
  content: ''; position: absolute; bottom: 0; left: 20%; right: 20%;
  height: 2px; background: #C9A84C;
}
.year-tabs button:hover { color: #fff; }

.directiva-info {
  text-align: center;
  font-size: 13px; color: rgba(255,255,255,.55);
  margin-bottom: 40px;
}

.org-chart {
  display: flex; flex-direction: column; align-items: center;
  gap: 60px;
  position: relative;
  transition: opacity .4s ease;
}
.org-chart.fading { opacity: 0; }
.org-level {
  display: flex; gap: 30px; flex-wrap: wrap; justify-content: center;
  position: relative;
}
.org-level::before {
  content: ''; position: absolute; top: -32px;
  width: 1px; height: 30px; background: rgba(201,168,76,.4);
  left: 50%; transform: translateX(-50%);
}
.org-level:first-child::before { display: none; }

.org-card,
.card--org {
  padding: 22px 18px;
  width: 200px;
  text-align: center;
}
.org-card:hover {
  transform: translateY(-6px);
  border-color: rgba(201,168,76,.6);
  box-shadow: 0 20px 40px rgba(0,0,0,.4);
}
.org-card .avatar {
  width: 84px; height: 84px; border-radius: 50%;
  margin: 0 auto 14px; overflow: hidden;
  background: #002040;
  border: 2px solid #C9A84C;
}
.org-card .avatar img { width: 100%; height: 100%; object-fit: cover; }
.org-card .cargo {
  font-size: 11px; letter-spacing: .2em; text-transform: uppercase;
  color: #C9A84C; margin-bottom: 6px; font-weight: 600;
}
.org-card .nombre {
  font-family: 'Fraunces', serif; font-weight: 700;
  font-size: 17px; margin-bottom: 4px;
}
.org-card .periodo { font-size: 11px; color: rgba(255,255,255,.5); }
.org-card .email {
  position: absolute; bottom: -28px; left: 50%; transform: translateX(-50%);
  font-size: 11px; color: rgba(201,168,76,.9);
  opacity: 0; transition: opacity .25s;
  white-space: nowrap;
}
.org-card:hover .email { opacity: 1; }
.org-card.level-1 { background: linear-gradient(135deg, rgba(201,168,76,.18), rgba(201,168,76,.05)); border-color: rgba(201,168,76,.5); }

.directiva-footnote {
  text-align: center; margin-top: 60px;
  font-size: 12px; color: rgba(255,255,255,.4);
  font-style: italic;
}

/* ==========================================================
   MODAL
   ========================================================== */
.modal-overlay {
  position: fixed; inset: 0; z-index: 9000;
  background: rgba(0,5,8,.85); backdrop-filter: blur(8px);
  display: flex; align-items: center; justify-content: center;
  padding: 20px;
  opacity: 0; pointer-events: none;
  transition: opacity .3s;
}
.modal-overlay.open { opacity: 1; pointer-events: auto; }
.modal-box {
  width: 100%; max-width: 720px;
  max-height: 90vh; overflow-y: auto;
  padding: 40px;
  position: relative;
  transform: scale(.95);
  transition: transform .3s;
}
.modal-overlay.open .modal-box { transform: scale(1); }
.modal-close {
  position: absolute; top: 16px; right: 16px;
  width: 36px; height: 36px; border-radius: 50%;
  background: rgba(255,255,255,.1); font-size: 20px;
}
.modal-box h3 {
  font-family: 'Fraunces', serif;
  font-size: 28px; margin-bottom: 8px;
}
.modal-box .modal-meta { color: rgba(255,255,255,.6); margin-bottom: 20px; font-size: 14px; }
.modal-box p { color: rgba(255,255,255,.75); margin-bottom: 16px; line-height: 1.7; }
.modal-stats {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
  gap: 12px; margin-top: 24px;
}
.modal-stats .stat {
  background: rgba(255,255,255,.05); padding: 14px;
  border-radius: 12px; text-align: center;
}
.modal-stats .stat .label {
  font-size: 11px; letter-spacing: .15em; text-transform: uppercase;
  color: rgba(255,255,255,.5); margin-bottom: 4px;
}
.modal-stats .stat .val {
  font-size: 18px; font-weight: 600; color: #C9A84C;
}

/* ==========================================================
   FOOTER
   ========================================================== */
footer {
  background: rgba(0,15,30,.75);
  border-top: 1px solid rgba(255,255,255,.2);
  padding: 80px 24px 40px;
  text-align: center; color: rgba(255,255,255,.7);
  font-size: 13px;
  letter-spacing: .08em;
  margin-top: 120px;
}
footer .brand-mark {
  font-family: 'Fraunces', serif; font-size: 28px;
  color: #C9A84C; margin-bottom: 16px; letter-spacing: .12em;
  font-weight: 700;
}
footer .tagline {
  color: rgba(255,255,255,.6);
  font-size: 14px;
  margin-bottom: 40px;
  font-weight: 300;
  line-height: 1.6;
}
footer .footer-links {
  display: flex;
  justify-content: center;
  gap: 32px;
  flex-wrap: wrap;
  margin-bottom: 40px;
}
footer .footer-links a {
  color: rgba(255,255,255,.7);
  text-decoration: none;
  transition: color .3s ease;
  font-size: 12px;
  text-transform: uppercase;
}
footer .footer-links a:hover {
  color: #C9A84C;
}
footer .footer-divider {
  height: 1px;
  background: rgba(255,255,255,.1);
  margin: 32px 0;
}
footer .footer-credits {
  color: rgba(255,255,255,.5);
  font-size: 11px;
  letter-spacing: .1em;
}

/* ==========================================================
   SCROLL PROGRESS
   ========================================================== */
#progress-bar {
  position: fixed; top: 0; left: 0;
  height: 2px; background: linear-gradient(90deg, #C9A84C, #00ffaa);
  z-index: 250; width: 0%;
  transition: width .15s linear;
}

/* ==========================================================
   MISIÓN / DISCIPLINAS / HISTORIA / TIMELINE / HORARIOS / TABLAS / CONTACTO
   ========================================================== */
.mision-card {
  max-width: 880px; margin: 0 auto;
  padding: 50px;
  background: linear-gradient(135deg, rgba(201,168,76,.18), rgba(201,168,76,.12));
  border: 1px solid rgba(201,168,76,.4);
  border-radius: 22px; position: relative;
  text-align: center;
}
/* Cita especial — mantener opacidad mayor para énfasis */
.mision-quote {
  font-family: 'Fraunces', serif;
  font-size: clamp(18px, 2.2vw, 24px);
  line-height: 1.6;
  color: rgba(255,255,255,.92);
  font-style: italic;
}
.mision-card::before {
  content: '"'; position: absolute; top: 0; left: 28px;
  font-family: 'Fraunces', serif; font-size: 120px;
  color: rgba(201,168,76,.15); line-height: 1;
}
.disciplinas-grid {
  display: flex; flex-wrap: wrap; gap: 12px; justify-content: center;
  margin-top: 50px;
}
.disc-pill {
  padding: 12px 22px; border-radius: 999px;
  background: rgba(255,255,255,.05);
  border: 1px solid rgba(201,168,76,.3);
  color: rgba(255,255,255,.9);
  font-size: 13px; letter-spacing: .08em;
  transition: all .3s;
}
.disc-pill:hover {
  background: rgba(201,168,76,.15);
  border-color: #C9A84C;
  transform: translateY(-2px);
}

/* Historia */
.historia-grid {
  display: grid;
  grid-template-columns: 1.4fr 1fr;
  gap: 60px;
  align-items: start;
}
@media (max-width: 860px) {
  .historia-grid { grid-template-columns: 1fr; gap: 40px; }
}
/* Heredar color y tamaño base */
.historia-text p {
  line-height: 1.85;
  margin-bottom: 18px;
  background: rgba(201, 168, 76, 0.12);
  padding: 18px 20px;
  border-radius: 10px;
  border-left: 3px solid rgba(201, 168, 76, 0.4);
  transition: all 0.3s ease;
}

.historia-text p:hover {
  background: rgba(201, 168, 76, 0.18);
  border-left-color: rgba(201, 168, 76, 0.6);
}
.historia-text strong { color: #C9A84C; font-weight: 600; }
.profes-block {
  background: rgba(0,15,30,.7);
  border: 1px solid rgba(255,255,255,.2);
  border-radius: 22px; padding: 32px;
}
.profes-title {
  font-family: 'Fraunces', serif;
  font-size: 22px; margin-bottom: 24px;
  color: #C9A84C;
}
.profe-card {
  display: flex; align-items: center; gap: 16px;
  padding: 16px; border-radius: 14px;
  background: rgba(255,255,255,.04);
  margin-bottom: 14px;
  transition: background .25s;
}
.profe-card:hover { background: rgba(201,168,76,.08); }
.profe-avatar {
  width: 52px; height: 52px; border-radius: 50%;
  background: linear-gradient(135deg, #C9A84C, #8e7530);
  display: flex; align-items: center; justify-content: center;
  font-weight: 700; color: #001F3F; font-size: 18px;
  flex-shrink: 0;
}
.profe-nombre {
  font-family: 'Fraunces', serif; font-weight: 700;
  font-size: 17px; color: #fff;
}
.profe-rol { font-size: 13px; color: rgba(255,255,255,.6); }

/* Timeline historia mundial */
.timeline {
  max-width: 800px; margin: 0 auto;
  position: relative;
  padding-left: 40px;
}
.timeline::before {
  content: ''; position: absolute;
  left: 16px; top: 12px; bottom: 12px;
  width: 2px; background: linear-gradient(180deg, transparent, rgba(201,168,76,.5), transparent);
}
.timeline-item {
  position: relative; padding: 28px 0 28px 30px;
}
.timeline-item::before {
  content: ''; position: absolute;
  left: -32px; top: 38px;
  width: 14px; height: 14px; border-radius: 50%;
  background: #C9A84C; border: 3px solid #001F3F;
  box-shadow: 0 0 0 2px rgba(201,168,76,.3);
}
.timeline-icon {
  position: absolute; left: -78px; top: 24px;
  font-size: 32px;
}
@media (max-width: 600px) {
  .timeline-icon { display: none; }
  .timeline { padding-left: 30px; }
}
.timeline-item h3 {
  font-family: 'Fraunces', serif;
  font-size: 22px; margin-bottom: 10px; color: #fff;
}
/* Heredar color base */
.timeline-item p {
  font-size: 15px;
  line-height: 1.75;
  background: rgba(201, 168, 76, 0.12);
  padding: 16px 18px;
  border-radius: 10px;
  border-left: 3px solid rgba(201, 168, 76, 0.4);
  margin-top: 10px;
  transition: all 0.3s ease;
}

.timeline-item p:hover {
  background: rgba(201, 168, 76, 0.18);
  border-left-color: rgba(201, 168, 76, 0.6);
}
.timeline-item em { color: #C9A84C; font-style: italic; }
.timeline-item strong { color: #C9A84C; }

/* Horarios */
.horarios-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 24px;
}
.horario-card {
  background: linear-gradient(180deg, rgba(255,255,255,.12), rgba(255,255,255,.08));
  border: 1px solid rgba(255,255,255,.2);
  border-radius: 22px; padding: 32px;
  transition: transform .3s, border-color .3s;
}
.horario-card:hover {
  transform: translateY(-6px);
  border-color: rgba(201,168,76,.4);
}
.horario-day {
  font-family: 'Fraunces', serif;
  font-size: 28px; color: #C9A84C; margin-bottom: 4px;
}
.horario-hour {
  font-family: 'Share Tech Mono', monospace;
  font-size: 13px; color: rgba(0,255,200,.7);
  letter-spacing: .12em; margin-bottom: 18px;
}
.horario-card h3 {
  font-size: 18px; margin-bottom: 10px; font-weight: 600;
}
/* Heredar color base */
.horario-card p {
  font-size: 14px;
  line-height: 1.6;
  background: rgba(201, 168, 76, 0.12);
  padding: 12px 14px;
  border-radius: 8px;
  border-left: 3px solid rgba(201, 168, 76, 0.4);
  margin: 8px 0;
  transition: all 0.3s ease;
}
.horario-card p:hover {
  background: rgba(201, 168, 76, 0.18);
  border-left-color: rgba(201, 168, 76, 0.6);
}

/* Tablas O2/CO2 */
.tablas-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 30px;
  max-width: 980px; margin: 0 auto;
}
@media (max-width: 720px) { .tablas-grid { grid-template-columns: 1fr; } }
.tabla-card,
.card--tabla {
  padding: 36px;
}
.tabla-tag {
  display: inline-block;
  font-family: 'Share Tech Mono', monospace;
  font-size: 32px; font-weight: 700;
  color: #00ffaa;
  background: rgba(0,255,170,.1);
  padding: 4px 14px; border-radius: 10px;
  margin-bottom: 18px;
  border: 1px solid rgba(0,255,170,.3);
}
.tabla-card h3 {
  font-family: 'Fraunces', serif;
  font-size: 26px; margin-bottom: 14px;
}
/* Heredar color base */
.tabla-card p {
  line-height: 1.75;
  font-size: 15px;
  background: rgba(201, 168, 76, 0.12);
  padding: 14px 16px;
  border-radius: 8px;
  border-left: 3px solid rgba(201, 168, 76, 0.4);
  margin: 10px 0;
  transition: all 0.3s ease;
}
.tabla-card p:hover {
  background: rgba(201, 168, 76, 0.18);
  border-left-color: rgba(201, 168, 76, 0.6);
}
.tabla-card strong { color: #00ffaa; }

/* Lugar / mapa */
#lugar .section-head { opacity: 1 !important; }
#lugar .eyebr